{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "dialog:allow-save",
    "dialog:allow-open",
    {
      "identifier": "fs:allow-read-file",
      "allow": [{ "path": "**" }]
    },
    {
      "identifier": "fs:allow-write-file",
      "allow": [{ "path": "**" }]
    },
    "fs:allow-watch",
    "fs:allow-unwatch",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "binaries/claude-agent-acp", "sidecar": true, "args": true },
        { "name": "codex-acp", "cmd": "codex-acp", "args": true },
        { "name": "gemini", "cmd": "gemini", "args": true },
        { "name": "binaries/norka-mcp", "sidecar": true, "args": true },
        { "name": "npm", "cmd": "npm", "args": true },
        { "name": "lsof", "cmd": "lsof", "args": true },
        { "name": "kill", "cmd": "kill", "args": true }
      ]
    },
    "shell:allow-stdin-write",
    "shell:allow-kill"
  ]
}
