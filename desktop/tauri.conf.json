{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Береста",
  "version": "0.12.0",
  "identifier": "io.norka.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Norka",
        "width": 1280,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/norka-mcp", "binaries/claude-agent-acp"],
    "macOS": {
      "signingIdentity": null
    }
  }
}
