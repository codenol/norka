{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nork",
  "version": "0.11.6",
  "identifier": "io.beresta.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Nork",
        "width": 1280,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/beresta-mcp", "binaries/claude-agent-acp"],
    "macOS": {
      "signingIdentity": null
    }
  }
}
